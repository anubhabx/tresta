{
  "name": "tresta",
  "version": "0.9.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "quality:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "lint": "turbo lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "validate:release": "turbo run lint --ui=stream && pnpm typecheck && pnpm test && turbo run build --ui=stream",
    "env:parity": "node ./scripts/check-env-parity.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "generate": "prisma generate --schema=./packages/database/prisma/schema.prisma",
    "widget:build": "pnpm --filter @workspace/widget build",
    "widget:dev": "pnpm --filter @workspace/widget dev",
    "widget:preview": "pnpm --filter @workspace/widget preview",
    "admin:dev": "pnpm --filter admin dev",
    "admin:build": "pnpm --filter admin build",
    "admin:start": "pnpm --filter admin start",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "postinstall": "turbo run generate"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "turbo": "^2.6.0",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20"
  }
}
